{
  "name": "noshorts-extension",
  "version": "1.0.0",
  "private": true,
  "description": "Chromium MV3 extension to block and hide YouTube Shorts.",
  "scripts": {
    "validate": "node scripts/validate-extension.mjs",
    "package": "powershell -ExecutionPolicy Bypass -File scripts/package.ps1",
    "package:chromium": "powershell -ExecutionPolicy Bypass -File scripts/package.ps1",
    "package:firefox": "powershell -ExecutionPolicy Bypass -File scripts/package-firefox.ps1",
    "package:safari-source": "powershell -ExecutionPolicy Bypass -File scripts/package-safari-source.ps1",
    "package:all": "npm run package:chromium && npm run package:firefox && npm run package:safari-source"
  }
}
